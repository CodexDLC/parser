APP_NAME="Project M4 AI Telegram News Bot"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
DEBUG=true
API_PREFIX="/api"
CABINET_ENABLED=false
CABINET_MOUNT_PATH="/cabinet"
DOCS_ENABLED=true
CABINET_USERNAME=""
CABINET_PASSWORD_HASH=""
CABINET_SESSION_SECRET=""
CABINET_SESSION_TTL_SECONDS=28800
CABINET_LOGIN_MAX_ATTEMPTS=5
CABINET_LOGIN_WINDOW_SECONDS=900
CABINET_TIMEZONE="Europe/Berlin"

DATABASE_URL="postgresql+asyncpg://m4:m4@localhost:5432/m4"
REDIS_URL="redis://localhost:6379/0"

PIPELINE_INTERVAL_SECONDS=1800
PIPELINE_PARSE_LIMIT=10
PIPELINE_GENERATION_LIMIT=10
PIPELINE_PUBLISHING_LIMIT=10
PIPELINE_RECONCILIATION_INTERVAL_SECONDS=600
PIPELINE_RUN_STALE_AFTER_SECONDS=7200

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.6-terra"
OPENAI_TIMEOUT_SECONDS=60

HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RESPONSE_BYTES=2000000
HTTP_USER_AGENT="Project-M4-RSS/0.1"

NEWS_ALLOWED_LANGUAGES="ru,en"

TELEGRAM_API_ID=
TELEGRAM_API_HASH=""
TELEGRAM_SESSION_NAME="m4_aibot"
TELEGRAM_TARGET_CHANNEL=""
TELEGRAM_DRY_RUN=true
